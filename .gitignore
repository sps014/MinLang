/target

.idea/

# Generated WASM artifacts emitted by the compiler/tests (e.g. tests/cases, sample/interop,
# and root scratch files). Hand-written runtime assets under src/ are NOT generated and are
# re-included below.
*.wat
*.wasm
*.abi.json

# Keep the hand-written runtime WAT assets that the codegen embeds via include_str!.
!/src/**/*.wat

node_modules/
.DS_Store