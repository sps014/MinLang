fun main(): void {
    let arr: int[] = [10, 20, 30];
    System.println(arr[0]);
    System.println(arr[1]);
    System.println(arr[2]);
    
    arr[1] = 50;
    System.println(arr[1]);
    
    let arr2: float[] = [1.5, 2.5];
    System.println(arr2[0]);
    System.println(arr2[1]);
    
    let arr3: string[] = ["hello", "world"];
    System.print(arr3[0]);
    System.print("\n");
    System.print(arr3[1]);
    System.print("\n");
}
