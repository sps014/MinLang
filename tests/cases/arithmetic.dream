fun main(): void {
    let a = 10;
    let b = 3;
    
    System.println(a + b);
    System.println(a - b);
    System.println(a * b);
    System.println(a / b);
    System.println(a % b);
    
    let x = 1.5;
    let y = 2.0;
    System.println(x + y);
    System.println(x * y);
    
    // Precedence
    System.println(1 + 2 * 3);
    System.println((1 + 2) * 3);
}
