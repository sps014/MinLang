async fun work(id: int): int {
    await Time.sleep(50);
    return id * id;
}

async fun main(): void {
    let a = work(2);
    let b = work(3);
    let results = await Promise.all([a, b]);
    System.println(results[0] + ", " + results[1]);

    let first = await Promise.any([work(10), work(20)]);
    System.println("first = " + first);
}
