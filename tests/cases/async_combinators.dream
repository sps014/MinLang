async fun work(id: int): int {
    await sleep(50);
    return id * id;
}

async fun main(): void {
    let a = work(2);
    let b = work(3);
    let results = await all([a, b]);
    println(to_string(results[0]) + ", " + to_string(results[1]));

    let first = await any([work(10), work(20)]);
    println("first = " + to_string(first));
}
