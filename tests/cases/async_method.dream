class Worker {
    public base: int;

    constructor(base: int) {
        this.base = base;
    }

    public async fun compute(n: int): int {
        await Time.sleep(10);
        return this.base + n;
    }

    public async fun twice(n: int): int {
        let once = await this.compute(n);
        return once + once;
    }
}

async fun main(): void {
    let w = Worker(100);
    let r = await w.compute(5);
    System.println(r);

    let t = await w.twice(1);
    System.println(t);
}
