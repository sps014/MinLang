fun main(): void {
    let a: char = 'A';
    let z: char = 'z';
    System.print(a);
    System.print(z);
    System.print('\n');

    let code: int = (int)a;
    System.print(to_string(code));
    System.print('\n');

    let next: char = (char)(code + 1);
    System.print(next);
    System.print('\n');

    let chars: char[] = ['h', 'i'];
    System.print(chars[0]);
    System.print(chars[1]);
    System.print('\n');

    if (a < z) {
        System.print(to_string(1));
    }
    System.print('\n');
}
