fun main(): void {
    let xs = List<int>();
    let i = 0;
    while (i < 100) {
        xs.push(i * 2);
        i = i + 1;
    }
    System.println(xs.size());
    System.println(xs.get(0).unwrap_or(0 - 1));
    System.println(xs.get(99).unwrap_or(0 - 1));

    let sum = 0;
    let j = 0;
    while (j < xs.size()) {
        sum = sum + xs.get(j).unwrap_or(0);
        j = j + 1;
    }
    System.println(sum);

    let words = List<string>();
    let k = 0;
    while (k < 20) {
        words.push("x");
        k = k + 1;
    }
    System.println(words.size());
    System.print(words.get(19).unwrap_or(""));
    System.print("\n");
    System.print(words.contains("x"));
    System.print("\n");
    System.print(words.contains("y"));
    System.print("\n");

    let squares = Map<int, int>();
    let n = 0;
    while (n < 64) {
        squares.put(n, n * n);
        n = n + 1;
    }
    System.println(squares.size());
    System.println(squares.get(12).unwrap_or(0 - 1));
    System.println(squares.get(63).unwrap_or(0 - 1));
}
