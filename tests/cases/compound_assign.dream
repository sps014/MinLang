class P { v: int; }

fun main(): void {
    let x: int = 10;
    x += 5;
    System.println(x);
    x -= 3;
    System.println(x);
    x *= 2;
    System.println(x);
    x /= 4;
    System.println(x);
    x %= 4;
    System.println(x);
    x++;
    System.println(x);
    x--;
    System.println(x);

    let arr: int[] = [1, 2, 3];
    arr[1] += 10;
    System.println(arr[1]);

    let p = P(5);
    p.v += 7;
    System.println(p.v);
}
