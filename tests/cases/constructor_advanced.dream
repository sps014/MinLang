// Generic class built via the implicit zero-arg default constructor.
class Box<T> {
    public value: T;
}

// Class holding a reference-typed field, built via the default constructor.
class Named {
    public name: string;
    public score: int;
}

// Custom constructor that derives a field, plus a destructor.
class Account {
    public owner: string;
    public balance: int;

    constructor(owner: string) {
        this.owner = owner;
        this.balance = 100;
    }

    del() {
        System.print("closing ");
        System.println(this.owner);
    }
}

fun open_account(owner: string) {
    let a = Account(owner);
    System.print(a.owner);
    System.print(" has ");
    System.println(a.balance);
}

fun main() {
    let b = Box<int>();
    b.value = 42;
    System.println(b.value);

    let n = Named();
    n.name = "Ada";
    n.score = 95;
    System.print(n.name);
    System.print(" ");
    System.println(n.score);

    open_account("Grace");
    open_account("Linus");
    System.println(0);
}
