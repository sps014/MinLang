// Generic class with an auto-generated constructor.
class Box<T> {
    value: T;
}

// Class holding a reference-typed field, built via the default constructor.
class Named {
    name: string;
    score: int;
}

// Custom constructor that derives a field, plus a destructor.
class Account {
    owner: string;
    balance: int;

    constructor(owner: string) {
        this.owner = owner;
        this.balance = 100;
    }

    del() {
        System.print("closing ");
        System.println(this.owner);
    }
}

fun open_account(owner: string) {
    let a = Account(owner);
    System.print(a.owner);
    System.print(" has ");
    System.println(a.balance);
}

fun main() {
    let b = Box<int>(42);
    System.println(b.value);

    let n = Named("Ada", 95);
    System.print(n.name);
    System.print(" ");
    System.println(n.score);

    open_account("Grace");
    open_account("Linus");
    System.println(0);
}
