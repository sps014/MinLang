// Auto-generated (default) constructor: Point(x, y) stores fields positionally.
class Point {
    x: int;
    y: int;
}

// Custom constructor via `constructor`, plus a destructor via `del`.
class Logged {
    id: int;

    constructor(id: int) {
        this.id = id;
        print("create ");
        println(this.id);
    }

    del() {
        print("drop ");
        println(this.id);
    }
}

fun make(n: int) {
    let temp = Logged(n);
    println(temp.id);
}

fun main() {
    let p = Point(3, 4);
    println(p.x);
    println(p.y);

    make(7);
    println(999);
}
