// Implicit zero-arg default constructor: Point() leaves fields at their zero value.
class Point {
    public x: int;
    public y: int;
}

// Custom constructor via `constructor`, plus a destructor via `del`.
class Logged {
    public id: int;

    constructor(id: int) {
        this.id = id;
        System.print("create ");
        System.println(this.id);
    }

    del() {
        System.print("drop ");
        System.println(this.id);
    }
}

fun make(n: int) {
    let temp = Logged(n);
    System.println(temp.id);
}

fun main() {
    let p = Point();
    p.x = 3;
    p.y = 4;
    System.println(p.x);
    System.println(p.y);

    make(7);
    System.println(999);
}
