// Auto-generated (default) constructor: Point(x, y) stores fields positionally.
class Point {
    public x: int;
    public y: int;
}

// Custom constructor via `constructor`, plus a destructor via `del`.
class Logged {
    public id: int;

    constructor(id: int) {
        this.id = id;
        System.print("create ");
        System.println(this.id);
    }

    del() {
        System.print("drop ");
        System.println(this.id);
    }
}

fun make(n: int) {
    let temp = Logged(n);
    System.println(temp.id);
}

fun main() {
    let p = Point(3, 4);
    System.println(p.x);
    System.println(p.y);

    make(7);
    System.println(999);
}
