enum Color { Red, Green, Blue }
enum Status { Active = 10, Inactive = 20 }

fun describe(c: Color): string {
    switch (c) {
        case Color.Red:
            return "red";
        case Color.Green:
            return "green";
        default:
            return "other";
    }
    return "unreachable";
}

fun main(): void {
    let c: Color = Color.Green;
    System.println(c);

    System.print(describe(c));
    System.print("\n");

    System.print(describe(Color.Blue));
    System.print("\n");

    let s: Status = Status.Inactive;
    System.println(s);

    if (c == Color.Green) {
        System.println(100);
    }
}
