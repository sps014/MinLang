enum Direction {
    North,
    East = 10,
    South,
    West,
}

fun main() {
    let d = Direction.South;
    System.println(d.to_string());
    System.println(Direction.North.to_string());
    System.println(Direction.West.to_string());
    System.print(Direction.East.to_string());
    System.println("!");
}
