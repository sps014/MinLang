extend int {
    public fun doubled(): int { return this * 2; }
}

fun main(): void {
    let n: Int32 = -7;
    System.println(n.abs());        // 7  (prelude extend)
    System.println(n.doubled());    // -14 (user extend)

    let s: String = "hello";
    System.println(s.length());     // 5  (prelude extend)
}
