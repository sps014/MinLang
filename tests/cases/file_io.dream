// Exercises the File API end-to-end under the native wasmtime harness: write, append, read back,
// then delete. The host functions are linked in tests/e2e_tests.rs (src/execution/host.rs).
async fun main(): void {
    let path = "dream_file_io_e2e.tmp";
    await File.write(path, "hello\n");
    await File.append(path, "dream");
    let text = await File.read(path);
    System.print(text);
    await File.delete(path);
}
