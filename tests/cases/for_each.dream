fun main(): void {
    let arr: int[] = [10, 20, 30];

    let sum: int = 0;
    for (let x in arr) {
        sum += x;
    }
    System.println(sum);

    let words: string[] = ["a", "b", "c"];
    for (let w in words) {
        System.print(w);
    }
    System.print("\n");

    let count: int = 0;
    for (let y in arr) {
        if (y == 20) { continue; }
        if (y == 30) { break; }
        count += 1;
    }
    System.println(count);

    let total: int = 0;
    for (let a in arr) {
        for (let b in arr) {
            total += 1;
        }
    }
    System.println(total);
}
