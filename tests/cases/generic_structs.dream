class Box<T> {
    val: T;
}

class Pair<T> {
    first: T;
    second: T;
}

fun print_box_int(b: Box<int>) {
    System.println(b.val);
}

fun print_box_float(b: Box<float>) {
    System.println(b.val);
}

fun main(): void {
    let int_box = Box<int>(42);
    let float_box = Box<float>(3.14159f);
    let str_box = Box<string>("Hello Generic Structs!\n");
    
    print_box_int(int_box);
    print_box_float(float_box);
    System.print(str_box.val);

    let p = Pair<int>(10, 20);
    System.println(p.first);
    System.println(p.second);
}