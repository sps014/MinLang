fun main(): void {
    System.println(int.parse("123").unwrap_or(0));
    System.println(int.parse("-45").unwrap_or(0));
    System.println(Int32.parse("7").unwrap_or(0));
    let n = 0 - 9;
    System.println(n.abs());
    let two = 2;
    System.println(two.pow(8));
    let a = 10;
    System.println(a.clamp(0, 5));
    let b = 3;
    System.println(b.min(7));
    System.println(b.max(7));
}
