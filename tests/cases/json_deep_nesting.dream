@json
class Geo {
    public lat: double;
    public lng: double;

    constructor(lat: double, lng: double) {
        this.lat = lat;
        this.lng = lng;
    }
}

@json
class Address {
    public city: string;
    public zip: string;
    public geo: Geo;

    constructor(city: string, zip: string, geo: Geo) {
        this.city = city;
        this.zip = zip;
        this.geo = geo;
    }
}

@json
class Company {
    public name: string;
    public address: Address;

    constructor(name: string, address: Address) {
        this.name = name;
        this.address = address;
    }
}

@json
class User {
    public name: string;
    public age: int;
    public company: Company;
    public tags: string[];

    constructor(name: string, age: int, company: Company, tags: string[]) {
        this.name = name;
        this.age = age;
        this.company = company;
        this.tags = tags;
    }
}

@json
class Team {
    public title: string;
    public lead: User;
    public members: User[];

    constructor(title: string, lead: User, members: User[]) {
        this.title = title;
        this.lead = lead;
        this.members = members;
    }
}

fun mk_user(name: string, age: int, city: string): User {
    return User(name, age, Company(city + " Corp", Address(city, "00000", Geo(1.5d, 2.5d))), [name, city]);
}

fun main(): void {
    let team = Team("Core", mk_user("Ada", 36, "London"), [mk_user("Bob", 30, "Paris"), mk_user("Cee", 41, "Berlin")]);

    let text = JSON.serialize(team);
    System.println(text);

    let back = JSON.deserialize<Team>(text);
    System.println(back.title);
    System.println(back.lead.name);
    System.println(back.lead.company.name);
    System.println(back.lead.company.address.city);
    System.println(back.lead.company.address.geo.lat);
    System.println(back.lead.tags[1]);
    System.println(back.members.size());
    System.println(back.members[0].name);
    System.println(back.members[1].company.address.geo.lng);
    System.println(back.members[1].age);

    // Round-trips identically.
    System.println(JSON.serialize(back) == text);
}
