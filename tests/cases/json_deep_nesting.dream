@json
class Geo {
    lat: double;
    lng: double;
}

@json
class Address {
    city: string;
    zip: string;
    geo: Geo;
}

@json
class Company {
    name: string;
    address: Address;
}

@json
class User {
    name: string;
    age: int;
    company: Company;
    tags: string[];
}

@json
class Team {
    title: string;
    lead: User;
    members: User[];
}

fun mk_user(name: string, age: int, city: string): User {
    return User {
        name: name,
        age: age,
        company: Company {
            name: city + " Corp",
            address: Address {
                city: city,
                zip: "00000",
                geo: Geo { lat: 1.5d, lng: 2.5d },
            },
        },
        tags: [name, city],
    };
}

fun main(): void {
    let team = Team {
        title: "Core",
        lead: mk_user("Ada", 36, "London"),
        members: [mk_user("Bob", 30, "Paris"), mk_user("Cee", 41, "Berlin")],
    };

    let text = JSON.serialize(team);
    System.println(text);

    let back = JSON.deserialize<Team>(text);
    System.println(back.title);
    System.println(back.lead.name);
    System.println(back.lead.company.name);
    System.println(back.lead.company.address.city);
    System.println(to_string(back.lead.company.address.geo.lat));
    System.println(back.lead.tags[1]);
    System.println(to_string(back.members.len()));
    System.println(back.members[0].name);
    System.println(to_string(back.members[1].company.address.geo.lng));
    System.println(to_string(back.members[1].age));

    // Round-trips identically.
    System.println(to_string(JSON.serialize(back) == text));
}
