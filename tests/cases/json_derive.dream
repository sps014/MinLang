@json
class Address {
    city: string;
    zip: string;
}

@json
class User {
    name: string;
    age: int;
    active: bool;
    address: Address;
    tags: string[];
    scores: int[];
}

fun main(): void {
    let u = User("Ada", 36, true, Address("London", "NW1"), ["dev", "math"], [10, 20, 30]);

    let text = JSON.serialize(u);
    System.println(text);

    let back = JSON.deserialize<User>(text);
    System.println(back.name);
    System.println(to_string(back.age));
    System.println(to_string(back.active));
    System.println(back.address.city);
    System.println(back.address.zip);
    System.println(back.tags[0]);
    System.println(back.tags[1]);
    System.println(to_string(back.scores[2]));
    System.println(JSON.serialize(back));
}
