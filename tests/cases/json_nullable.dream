@json
class Address { city: string; zip: string; }

@json
class Profile {
    name: string;
    nickname: string?;
    address: Address?;
    age: int;
}

fun main(): void {
    // Present values round-trip.
    let p1 = Profile { name: "Ada", nickname: "Countess", address: Address { city: "London", zip: "NW1" }, age: 36 };
    let t1 = JSON.serialize(p1);
    println(t1);
    let b1 = JSON.deserialize<Profile>(t1);
    println(b1.nickname ?? "<none>");
    let addr = b1.address;
    println(to_string(addr == null));

    // Null values serialize to JSON null and round-trip back to null.
    let p2 = Profile { name: "Bob", nickname: null, address: null, age: 20 };
    let t2 = JSON.serialize(p2);
    println(t2);
    let b2 = JSON.deserialize<Profile>(t2);
    println(b2.nickname ?? "<none>");
    println(to_string(b2.address == null));

    // A missing key and an explicit null both deserialize to null.
    let b3 = JSON.deserialize<Profile>("{\"name\":\"Cee\",\"nickname\":null,\"age\":7}");
    println(b3.nickname ?? "<none>");
    println(to_string(b3.address == null));
}
