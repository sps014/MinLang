@json
class Address { public city: string; public zip: string; }

@json
class Profile {
    public name: string;
    public nickname: string?;
    public address: Address?;
    public age: int;
}

fun main(): void {
    // Present values round-trip.
    let p1 = Profile("Ada", "Countess", Address("London", "NW1"), 36);
    let t1 = JSON.serialize(p1);
    System.println(t1);
    let b1 = JSON.deserialize<Profile>(t1);
    System.println(b1.nickname ?? "<none>");
    let addr = b1.address;
    System.println(addr == null);

    // Null values serialize to JSON null and round-trip back to null.
    let p2 = Profile("Bob", null, null, 20);
    let t2 = JSON.serialize(p2);
    System.println(t2);
    let b2 = JSON.deserialize<Profile>(t2);
    System.println(b2.nickname ?? "<none>");
    System.println(b2.address == null);

    // A missing key and an explicit null both deserialize to null.
    let b3 = JSON.deserialize<Profile>("{\"name\":\"Cee\",\"nickname\":null,\"age\":7}");
    System.println(b3.nickname ?? "<none>");
    System.println(b3.address == null);
}
