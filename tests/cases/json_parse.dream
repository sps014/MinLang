fun main(): void {
    let v = JSON.parse("{\"a\":{\"b\":[1,2,3]},\"s\":\"hi\\nthere\",\"n\":-2.5,\"ok\":false}");
    System.println(to_string(v.get("a").get("b").at(2).as_int()));
    System.println(to_string(v.get("a").get("b").size()));
    System.println(to_string(v.get("n").as_double()));
    System.println(to_string(v.get("ok").as_bool()));
    System.println(to_string(v.get("missing").is_null()));
    System.println(JSON.stringify(v.get("s")));
}
