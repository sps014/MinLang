@json
class Address {
    city: string;
    zip: string;

    constructor(city: string, zip: string) {
        this.city = city;
        this.zip = zip;
    }
}

@json
class User {
    name: string;
    age: int;
    address: Address;
    tags: string[];

    constructor(name: string, age: int, address: Address, tags: string[]) {
        this.name = name;
        this.age = age;
        this.address = address;
        this.tags = tags;
    }
}

fun main(): void {
    let u = User("Ada", 36, Address("London", "NW1"), ["dev", "math"]);

    System.println(JSON.stringify_pretty(u.to_json(), 2));

    let v = JSON.parse("{\"a\":[1,2],\"b\":{\"c\":true},\"d\":[]}");
    System.println(JSON.stringify_pretty(v, 4));

    // indent 0 falls back to compact output.
    System.println(JSON.stringify_pretty(v, 0));
}
