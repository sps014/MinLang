@json
class Product {
    @property_name("id")
    product_id: int;

    @property_name("title")
    name: string;

    @property_name("priceUsd")
    price: float;

    tags: string[]; // standard field
}

fun main(): void {
    let p = Product {
        product_id: 42,
        name: "Widget",
        price: 9.5,
        tags: ["sale", "new"]
    };

    let serialized = JSON.serialize(p);
    println(serialized);

    let deserialized = JSON.deserialize<Product>(serialized);
    println(deserialized.name);
    println(deserialized.product_id);
}