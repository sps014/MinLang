@json
class Product {
    @property_name("id")
    public product_id: int;

    @property_name("title")
    public name: string;

    @property_name("priceUsd")
    public price: float;

    public tags: string[]; // standard field

    constructor(product_id: int, name: string, price: float, tags: string[]) {
        this.product_id = product_id;
        this.name = name;
        this.price = price;
        this.tags = tags;
    }
}

fun main(): void {
    let p = Product(42, "Widget", 9.5, ["sale", "new"]);

    let serialized = JSON.serialize(p);
    System.println(serialized);

    let deserialized = JSON.deserialize<Product>(serialized);
    System.println(deserialized.name);
    System.println(deserialized.product_id);
}