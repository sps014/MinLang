@json
class Product {
    @property_name("id")
    product_id: int;

    @property_name("title")
    name: string;

    @property_name("priceUsd")
    price: float;

    tags: string[]; // standard field
}

fun main(): void {
    let p = Product(42, "Widget", 9.5, ["sale", "new"]);

    let serialized = JSON.serialize(p);
    System.println(serialized);

    let deserialized = JSON.deserialize<Product>(serialized);
    System.println(deserialized.name);
    System.println(deserialized.product_id);
}