fun main(): void {
    let user = JsonValue.dict();
    user.set("name", JsonValue.from_string("Ada"));
    user.set("age", JsonValue.from_int(36));
    let tags = JsonValue.array();
    tags.push(JsonValue.from_string("dev"));
    tags.push(JsonValue.from_string("math"));
    user.set("tags", tags);
    user.set("active", JsonValue.boolean(true));

    System.println(JSON.stringify(user));

    let parsed = JSON.parse(JSON.stringify(user));
    let none = JsonValue.none();
    System.println(parsed.get("name").unwrap_or(none).as_string());
    System.println(parsed.get("age").unwrap_or(none).as_int());
    System.println(parsed.get("tags").unwrap_or(none).at(1).unwrap_or(none).as_string());
    System.println(parsed.get("active").unwrap_or(none).as_bool());
    System.println(parsed.get("tags").unwrap_or(none).size());
}
