fun main(): void {
    let xs = List<int>();
    xs.push(10);
    xs.push(20);
    xs.push(30);
    System.println(xs.size());
    System.println(xs.get(0));
    System.println(xs.get(2));
    xs.set(1, 99);
    System.println(xs.get(1));
    System.println(xs.pop());
    System.println(xs.size());
    System.println(xs.index_of(99));
    System.print(xs.contains(99));
    System.print("\n");
    System.print(xs.contains(12345));
    System.print("\n");

    let i = 0;
    while (i < 50) {
        xs.push(i);
        i = i + 1;
    }
    System.println(xs.size());
    System.println(xs.get(51));

    xs.remove_at(0);
    System.println(xs.get(0));
    System.println(xs.size());

    let names = List<string>();
    names.push("alpha");
    names.push("beta");
    System.print(names.get(0));
    System.print("\n");
    System.print(names.contains("beta"));
    System.print("\n");
    System.println(names.index_of("beta"));
}
