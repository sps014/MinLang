// Exercises the stdlib `List<T>.length` getter/setter property (dot access, not a method call).
fun main(): void {
    let xs = List<int>();
    xs.push(10);
    xs.push(20);
    xs.push(30);

    System.println(xs.length);   // 3 (getter)

    xs.length = 1;               // setter truncates to first element
    System.println(xs.length);   // 1

    xs.length = 99;              // out of range: ignored
    System.println(xs.length);   // 1
}
