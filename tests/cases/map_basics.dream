fun main(): void {
    let m = Map<string, int>();
    m.put("one", 1);
    m.put("two", 2);
    m.put("three", 3);
    System.println(m.size());
    System.println(m.get("one"));
    System.println(m.get("three"));
    System.print(m.contains("two"));
    System.print("\n");
    System.print(m.contains("nope"));
    System.print("\n");
    System.println(m.get("missing"));
    System.println(m.get_or("missing", -1));
    m.put("two", 22);
    System.println(m.get("two"));
    System.println(m.size());
    System.print(m.remove("two"));
    System.print("\n");
    System.println(m.size());
    System.print(m.contains("two"));
    System.print("\n");
    System.println(m.get("two"));

    let counts = Map<int, int>();
    let i = 0;
    while (i < 40) {
        counts.put(i, i * i);
        i = i + 1;
    }
    System.println(counts.size());
    System.println(counts.get(7));
    System.println(counts.get(39));
    System.print(counts.contains(40));
    System.print("\n");
    System.println(counts.get_or(40, -7));
}
