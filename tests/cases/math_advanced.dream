fun main(): void {
    let p = Math.pow(2.0d, 3.0d);
    println(to_string(p));

    let f = Math.floor(3.7d);
    println(to_string(f));

    let c = Math.ceil(3.2d);
    println(to_string(c));

    let r = Math.round(3.5d);
    println(to_string(r));
    
    let a = Math.abs(-42.5d);
    println(to_string(a));
    
    let s = Math.sqrt(16.0d);
    println(to_string(s));

    let z = Math.sin(0.0d);
    println(to_string(z));
}