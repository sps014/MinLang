class Node {
    public value: int;
    public next: Node?;

    constructor(value: int, next: Node?) {
        this.value = value;
        this.next = next;
    }
}

fun create_list(n: int): Node? {
    if (n <= 0 ) {
        return null;
    }
    let head = Node(n, null);
    let curr: Node? = head;
    let i = n - 1;
    while (i > 0 ) {
        curr.next = Node(i, null);
        curr = curr.next;
        i = i - 1;
    }
    return head;
}

fun main(): void {
    // Allocate a large linked list to test allocator and ARC performance
    let list = create_list(10000);
    System.print("Memory was allocated and freed successfully!\n");
}
