// Multiple generic parameters: two-parameter class (with a method using both params),
// two-parameter functions, and a mangling-collision check between Pair<int, float> and
// Pair<int, double> (which previously both collapsed to "Pair_int").
class Pair<K, V> {
    public key: K;
    public value: V;

    constructor(key: K, value: V) {
        this.key = key;
        this.value = value;
    }

    public fun show() {
        System.println(this.key);
        System.print(this.value);
    }
}

fun first<A, B>(a: A, b: B): A {
    return a;
}

fun second<A, B>(a: A, b: B): B {
    return b;
}

fun main() {
    let p = Pair<int, string>(1, "one\n");
    p.show();

    let q = Pair<int, float>(2, 2.5f);
    System.println(q.value);

    let r = Pair<int, double>(3, 3.5d);
    System.println(r.value);

    System.println(first<int, string>(10, "ten"));
    let s = second<int, string>(10, "two\n");
    System.print(s);
}
