class Box<T> {
    public v: T;

    constructor(v: T) {
        this.v = v;
    }
}

class Pair<A, B> {
    public first: A;
    public second: B;

    constructor(first: A, second: B) {
        this.first = first;
        this.second = second;
    }
}

fun main() {
    let b = Box<Box<int>>(Box<int>(7));
    System.println(b.v.v);

    let p = Pair<Box<int>, int>(Box<int>(99), 5);
    System.println(p.first.v);
    System.println(p.second);
}
