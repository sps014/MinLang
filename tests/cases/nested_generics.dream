class Box<T> {
    v: T;
}

class Pair<A, B> {
    first: A;
    second: B;
}

fun main() {
    let b = Box<Box<int>> { v: Box<int> { v: 7 } };
    System.println(b.v.v);

    let p = Pair<Box<int>, int> { first: Box<int> { v: 99 }, second: 5 };
    System.println(p.first.v);
    System.println(p.second);
}
