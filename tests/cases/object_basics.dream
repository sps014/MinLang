// Object type: boxing primitives, to_string, unboxing via cast, runtime `is`,
// and reference (pointer) equality.
fun main() {
    let o: object = 42;
    System.print(o);
    System.print("\n");

    let n: int = (int)o;
    System.println(n);

    let s: object = "hi";
    System.print(s);
    System.print("\n");

    let b: object = true;
    System.print(b);
    System.print("\n");

    if (o is int) { System.print("o is int\n"); }
    if (s is string) { System.print("s is string\n"); }
    if (o is string) { System.print("o is string\n"); } else { System.print("o not string\n"); }

    let a: object = "x";
    let c: object = a;
    if (a == c) { System.print("same\n"); }

    System.print((7).hash_code());
    System.print("\n");
}
