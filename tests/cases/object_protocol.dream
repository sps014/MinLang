// The object protocol: compile-time generated default to_string/hash_code for a class,
// and @override export implementations for another class, plus runtime dispatch through
// an `object`.
class Point {
    x: int;
    y: int;
}

class Named {
    id: int;
    label: string;

    @override export fun to_string(): string {
        return "Named#" + to_string(this.id);
    }

    @override export fun hash_code(): int {
        return this.id;
    }
}

fun main() {
    let p = Point { x: 3, y: 7 };
    System.print(to_string(p));
    System.print("\n");
    System.println(hash_code(p));

    let n = Named { id: 5, label: "hello" };
    System.print(to_string(n));
    System.print("\n");
    System.println(hash_code(n));

    let o: object = p;
    System.print(to_string(o));
    System.print("\n");
}
