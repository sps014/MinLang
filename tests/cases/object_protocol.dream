// The object protocol: compile-time generated default to_string/hash_code for a class,
// and @override public implementations for another class, plus runtime dispatch through
// an `object`.
class Point {
    x: int;
    y: int;
}

class Named {
    id: int;
    label: string;

    @override public fun to_string(): string {
        return "Named#" + this.id;
    }

    @override public fun hash_code(): int {
        return this.id;
    }
}

fun main() {
    let p = Point(3, 7);
    System.print(p);
    System.print("\n");
    System.println(p.hash_code());

    let n = Named(5, "hello");
    System.print(n);
    System.print("\n");
    System.println(n.hash_code());

    let o: object = p;
    System.print(o);
    System.print("\n");
}
