// Overloaded extension methods on a primitive resolve by argument type. `this` is the int
// value (a stack value), supplied implicitly as the receiver.
extend int {
    public fun combine(other: int): int { return this + other; }
    public fun combine(other: string): int { return this + 100; }
}

fun main(): void {
    let n: int = 5;
    System.println(n.combine(3));     // 8    (int overload)
    System.println(n.combine("x"));   // 105  (string overload)
}
