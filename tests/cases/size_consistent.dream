// `size()` is the single, uniform element-count accessor across every collection: raw arrays,
// strings, `List`, and `Map` all answer to the same `.size()`.
fun main(): void {
    let a = Array.new<int>(4);
    System.println(a.size());     // 4  (array)

    let s = "hello";
    System.println(s.size());     // 5  (string)

    let xs = List<int>();
    xs.push(10);
    xs.push(20);
    xs.push(30);
    System.println(xs.size());    // 3  (list)

    let m = Map<string, int>();
    m.set("a", 1);
    m.set("b", 2);
    System.println(m.size());     // 2  (map)
}
