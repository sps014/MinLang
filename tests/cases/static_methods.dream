class Vec2 {
    public x: int;
    public y: int;

    constructor(x: int, y: int) {
        this.x = x;
        this.y = y;
    }

    public static fun origin(): Vec2 {
        return Vec2(0, 0);
    }

    public static fun of(x: int, y: int): Vec2 {
        return Vec2(x, y);
    }

    public fun sum(): int {
        return this.x + this.y;
    }
}

fun main(): void {
    let o = Vec2.origin();
    System.println(o.sum());
    let p = Vec2.of(3, 4);
    System.println(p.sum());
    System.println(int.parse("100").unwrap_or(0));
}
