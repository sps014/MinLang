// Static TypeScript-style property accessors: read/written through the type itself
// (`Type.prop` / `Type.prop = v`) with no instance receiver. Distinct from instance accessors.
class Settings {
    // A static getter computes a value on read of `Settings.version`.
    public static get version(): int {
        return 7;
    }

    // A static setter runs on write of `Settings.level = v`; here it echoes the value.
    public static set level(value: int) {
        System.println(value);
    }
}

fun main(): void {
    System.println(Settings.version);   // 7
    Settings.level = 3;                 // 3
    Settings.level = Settings.version;  // 7
}
