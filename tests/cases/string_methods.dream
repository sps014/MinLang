fun main(): void {
    let s = "Hello, World";
    System.println(s.length());
    System.println(s.substring(0, 5));
    System.println(s.substring(7, 12));
    System.println(s.to_lower());
    System.println(s.to_upper());
    System.println(s.index_of('o').unwrap_or(0 - 1));
    System.println(s.contains("World"));
    System.println(s.starts_with("Hell"));
    System.println(s.ends_with("rld"));
    let pad = "  trimmed  ";
    System.println(pad.trim());
    let ab = "ab";
    System.println(ab.repeat(3));
    System.println(s.equals("Hello, World"));
}
