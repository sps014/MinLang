fun print_greeting(name: string): void {
    let greeting = "Hello, " + name;
    System.print(greeting);
    System.print("\n");
}

fun main(): void {
    let a = "hello ";
    let b = "world";
    let c = a + b;
    
    System.print(c);
    System.print("\n");
    
    print_greeting("Alice");
    print_greeting("Bob");
}
