class Point<T> {
    x: T;
    y: T;
}

class Pixel {
    r: int;
    g: int;
}

fun main() {
    let pts: Point<int>[] = [Point<int> { x: 1, y: 2 }, Point<int> { x: 3, y: 4 }];
    System.println(pts.len());
    System.println(pts[0].x);
    System.println(pts[1].y);

    let px: Pixel[] = [Pixel { r: 10, g: 20 }];
    System.println(px[0].r);
    System.println(px[0].g);
}
