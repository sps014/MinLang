class Point<T> {
    public x: T;
    public y: T;

    constructor(x: T, y: T) {
        this.x = x;
        this.y = y;
    }
}

class Pixel {
    public r: int;
    public g: int;

    constructor(r: int, g: int) {
        this.r = r;
        this.g = g;
    }
}

fun main() {
    let pts: Point<int>[] = [Point<int>(1, 2), Point<int>(3, 4)];
    System.println(pts.len());
    System.println(pts[0].x);
    System.println(pts[1].y);

    let px: Pixel[] = [Pixel(10, 20)];
    System.println(px[0].r);
    System.println(px[0].g);
}
