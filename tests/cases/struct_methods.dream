class Counter {
    public count: int;

    public fun increment() {
        this.count = this.count + 1;
    }

    public fun add(amount: int) {
        this.count = this.count + amount;
    }

    public fun get(): int {
        return this.count;
    }
}

class GenericBox<T> {
    public val: T;

    public fun print_val() {
        if (this.val is int) {
            System.println(this.val);
        } else if (this.val is float) {
            System.println(this.val);
        } else if (this.val is string) {
            System.print(this.val);
        }
    }

    public fun set_val(new_val: T) {
        this.val = new_val;
    }
}

fun main() {
    let c = Counter(0);
    c.increment();
    c.add(4);
    System.println(c.get());

    let int_box = GenericBox<int>(42);
    int_box.print_val();
    int_box.set_val(100);
    int_box.print_val();

    let str_box = GenericBox<string>("Hello Methods\n");
    str_box.print_val();
}