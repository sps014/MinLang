class Point {
    public x: int;
    public y: int;
}

class Rect {
    public p1: Point;
    public p2: Point;
}

fun main(): void {
    let p1 = Point();
    p1.x = 10;
    p1.y = 20;
    let p2 = Point();
    p2.x = 30;
    p2.y = 40;

    let r = Rect();
    r.p1 = p1;
    r.p2 = p2;
    
    System.println(r.p1.x);
    System.println(r.p1.y);
    System.println(r.p2.x);
    System.println(r.p2.y);
    
    r.p1.x = 100;
    System.println(r.p1.x);
    System.println(p1.x); // Should also be 100 since it's a reference
}