class Point {
    public x: int;
    public y: int;
}

class Rect {
    public p1: Point;
    public p2: Point;
}

fun main(): void {
    let p1 = Point(10, 20);
    let p2 = Point(30, 40);
    
    let r = Rect(p1, p2);
    
    System.println(r.p1.x);
    System.println(r.p1.y);
    System.println(r.p2.x);
    System.println(r.p2.y);
    
    r.p1.x = 100;
    System.println(r.p1.x);
    System.println(p1.x); // Should also be 100 since it's a reference
}