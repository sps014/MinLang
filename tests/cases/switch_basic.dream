fun classify(n: int): string {
    switch (n) {
        case 1, 2, 3:
            return "small";
        case 10:
            return "ten";
        default:
            return "other";
    }
    return "unreachable";
}

fun main(): void {
    System.print(classify(2));
    System.print("\n");
    System.print(classify(10));
    System.print("\n");
    System.print(classify(99));
    System.print("\n");

    let s: string = "hi";
    switch (s) {
        case "hi":
            System.println(1);
        case "bye":
            System.println(2);
        default:
            System.println(0);
    }
}
