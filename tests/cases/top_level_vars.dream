// Top-level `let`/`const` variables become WASM globals. Initializers run once at module
// start (in declaration order) and may reference earlier globals.
let counter: int = 10;
const FACTOR: int = 3;
let derived: int = counter * FACTOR;

fun main(): void {
    System.println(counter);
    System.println(FACTOR);
    System.println(derived);

    counter = counter + 5;
    System.println(counter);

    derived = counter * FACTOR;
    System.println(derived);
}
