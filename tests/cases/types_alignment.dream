class Mixed {
    public b1: bool;
    public i1: int;
    public d1: double;
    public b2: bool;

    constructor(b1: bool, i1: int, d1: double, b2: bool) {
        this.b1 = b1;
        this.i1 = i1;
        this.d1 = d1;
        this.b2 = b2;
    }
}

fun main(): void {
    let m = Mixed(true, 42, 3.14159d, false);
    
    if (m.b1 ) {
        System.println(m.i1);
    }
    
    System.println(m.d1);
    
    m.d1 = 2.718d;
    System.println(m.d1);
}
