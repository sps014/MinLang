class Mixed {
    public b1: bool;
    public i1: int;
    public d1: double;
    public b2: bool;
}

fun main(): void {
    let m = Mixed(true, 42, 3.14159d, false);
    
    if (m.b1 ) {
        System.println(m.i1);
    }
    
    System.println(m.d1);
    
    m.d1 = 2.718d;
    System.println(m.d1);
}
