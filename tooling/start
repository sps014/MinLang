#!/usr/bin/env bash
# Starts the Dream web playground: installs deps (first run), builds the WebAssembly language
# service, then launches the Vite dev server. Works from any directory by resolving its own
# location.
set -euo pipefail

# Directory this script lives in (tooling/), regardless of the caller's cwd.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WEB_DIR="$SCRIPT_DIR/web"

cd "$WEB_DIR"

# Install node dependencies only when they are missing (fast on subsequent runs).
if [ ! -d node_modules ]; then
  echo "==> Installing web dependencies..."
  npm install
fi

echo "==> Building the WebAssembly analyzer..."
npm run build:wasm

echo "==> Starting the dev server..."
npm run dev
