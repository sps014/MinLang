{
  "name": "dream-lang",
  "version": "0.1.0",
  "description": "Dream language support for VS Code",
  "publisher": "dream-lang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:dream"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dream",
        "extensions": [
          ".dream"
        ],
        "icon": {
          "light": "./icons/dream.svg",
          "dark": "./icons/dream.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "dream",
        "scopeName": "source.dream",
        "path": "./syntaxes/dream.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
