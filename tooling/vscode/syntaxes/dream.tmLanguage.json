{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Dream",
  "scopeName": "source.dream",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#entities" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.dream",
          "match": "//.*$"
        },
        {
          "name": "comment.block.dream",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dream",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.dream",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.dream",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.dream",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dream",
          "match": "\\b(if|else|for|while|do|return|break|continue|switch|case|default|is|in|async|await)\\b"
        },
        {
          "name": "storage.type.dream",
          "match": "\\b(let|const|class|enum|type|extend|fun)\\b"
        },
        {
          "name": "storage.modifier.dream",
          "match": "\\b(static|public|extern|import)\\b"
        },
        {
          "name": "variable.language.this.dream",
          "match": "\\bthis\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.dream",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "constant.numeric.dream",
          "match": "\\b[0-9]+(\\.[0-9]+)?([dDfF])?\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.dream",
          "match": "\\b(int|float|double|string|bool|char|void|object)\\b"
        },
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
          "name": "entity.name.type.class.dream"
        }
      ]
    },
    "entities": {
      "patterns": [
        {
          "match": "\\b(fun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.dream" },
            "2": { "name": "entity.name.function.dream" }
          }
        },
        {
          "match": "\\b(class|enum|extend)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.dream" },
            "2": { "name": "entity.name.type.class.dream" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "name": "entity.name.function.dream"
        },
        {
          "match": "(?<=\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*\\()",
          "name": "entity.name.function.member.dream"
        },
        {
          "match": "(?<=\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "name": "variable.other.property.dream"
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:)",
          "name": "variable.parameter.dream"
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "name": "variable.other.dream"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.dream",
          "match": "(\\+|-|\\*|/|%|==|!=|>|<|>=|<=|&&|\\|\\||!|=|\\+=|-=|\\*=|/=|%=|\\+\\+|--|\\?|:)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.dream",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.dream",
          "match": ","
        }
      ]
    }
  }
}